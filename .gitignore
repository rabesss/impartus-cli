# Allowlisting gitignore template for GO projects prevents us
# from adding various unwanted local files, such as generated
# files, developer configurations or IDE-specific files etc.
#
# Recommended: Go.AllowList.gitignore

# Ignore everything
*

# But not these files...
!/.gitignore
!/.golangci.yml
!/.pre-commit-config.yaml
!/.github/
!/.github/**
!/AGENTS.md
!/.dockerignore
!/.env.example
!/.release-please-manifest.json

!*.go
!go.sum
!go.mod

!/CHANGELOG.md
!/Dockerfile
!README.md
!/release-please-config.json
!shell.nix
!docs/**


!sample.config.json
!fixtures/**
!assets/**
!Makefile

# AI code-review bot configs (must be committed so the bots can read them)
!/REVIEW.md
!/.coderabbit.yaml
!/.pr_agent.toml
!/best_practices.md
!/socket.yml
!/.gemini/config.yaml
!/.gemini/styleguide.md

# ...even if they are in subdirectories
!*/

# Build/coverage artifacts
coverage*.out
*.test

# Local agent/tooling workspaces
.beads/
.btca/
.claude/
CLAUDE.md


# Factory validation and mission state (ignored, never committed)
.factory/

# Credentials and secrets
.token
*.token
config.json



# Desloppify quality gate local state
.desloppify/
scorecard.png
query.json



# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
