# Allowlisting gitignore template for GO projects prevents us
# from adding various unwanted local files, such as generated
# files, developer configurations or IDE-specific files etc.
#
# Recommended: Go.AllowList.gitignore

# Ignore everything
*

# But not these files...
!/.gitignore
!/.golangci.yml
!/.pre-commit-config.yaml
!/.github/
!/.github/**
!/.dockerignore
!/.env.example
!/.release-please-manifest.json

!*.go
!go.sum
!go.mod

!/CHANGELOG.md
!/Dockerfile
!README.md
!CONTRIBUTING.md
!SECURITY.md
!/release-please-config.json
!shell.nix
!docs/**


!sample.config.json
!fixtures/**
!assets/**
!Makefile
!/scripts/desloppify-golangci-lint-adapter.sh
!/scripts/test-desloppify-golangci-lint-adapter.sh
!/scripts/run-quality-gate.sh
!/scripts/test-quality-gate.sh

# ...even if they are in subdirectories
!*/

# Build/coverage artifacts
coverage*.out
*.test

# Local agent/tooling workspaces and agent docs (never commit)
.beads/
.btca/
.claude/
AGENTS.md
REVIEW.md
best_practices.md
CLAUDE.md
**/CLAUDE.md
opencode.json
!/opencode.json
.coderabbit.yaml
.pr_agent.toml
socket.yml
.gemini/
.github/copilot-instructions.md
.github/instructions/
.deepsec/


# Factory validation and mission state (ignored, never committed)
.factory/

# Credentials and secrets
.token
*.token
config.json



# Desloppify quality gate local state
.venv-desloppify/
.desloppify/
scorecard.png
query.json



# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
