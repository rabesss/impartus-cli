{
  // ============================================
  // Impartus CLI Configuration
  // ============================================
  // Copy this file to config.json and fill in your credentials.
  // All fields are optional unless marked as required.

  // === Required Fields ===
  "username": "your_impartus_email@example.com",       // Impartus username (email) - REQUIRED
  "password": "your_impartus_password",                 // Impartus password - REQUIRED
  "baseUrl": "https://a.impartus.com/api",             // Impartus API base URL - REQUIRED

  // === Video Quality & Views ===
  "quality": "144",                                     // Default video quality: 144|450|720
  "views": "both",                                     // Default views: left|right|both (or first|second|both)

  // === Download Settings ===
  "downloadLocation": "./downloads",                   // Default output directory for downloads
  "tempDirLocation": "./.temp",                        // Temporary directory for intermediate files
  "slides": false,                                     // Download slides alongside video (true/false)
  "audioOnly": false,                                  // Download audio only, no video (true/false)
  "audioFormat": "mp3",                                // Audio format when audioOnly=true: mp3|m4a|aac|opus
  "skipNoAudio": false,                                // Skip lectures with no audio track (true/false)

  // === Concurrency Settings ===
  "numWorkers": 5,                                     // Concurrent workers for downloads (1-50, default: 5)
  "rateLimit": 10,                                     // Download rate limit (requests/second, 0.1-100)
  "apiRateLimit": 2,                                   // API rate limit (requests/second, 0.1-20)

  // === Pipeline Settings ===
  // When enablePipeline=true, downloads and decryption run concurrently for faster throughput
  "enablePipeline": false,                             // Enable pipelined download+decrypt mode (true/false)
  "downloadWorkersPerLecture": 3,                       // Parallel download workers per lecture (1-10, default: 3)
  "decryptWorkersPerLecture": 2,                        // Parallel decrypt workers per lecture (1-10, default: 2)

  // === HTTP Settings ===
  "httpTimeout": "10m",                                // HTTP timeout for chunk downloads (30s-60m, default: 10m)
  "enableJitter": true,                                // Add random delays to reduce server load (true/false)

  // === Progress Tracking ===
  "progressTracking": {
    "enabled": true,                                   // Enable progress bars (true/false)
    "showSpeed": true,                                 // Show download speed in progress (true/false)
    "showETA": true,                                   // Show estimated time remaining (true/false)
    "updateInterval": "2s",                            // Progress update interval (500ms-10s, default: 2s)
    "speedWindowSize": 10                              // Speed moving average window size (3-30, default: 10)
  },

  // === Feature Flags ===
  // Feature flags enable experimental features and safe rollouts.
  // Can also be set via environment variables: IMPARTUS_FLAG_<FEATURE_NAME>=true|false
  // Available flags and their env vars:
  //   IMPARTUS_FLAG_VERBOSE_LOGGING - Enable verbose logging
  //   IMPARTUS_FLAG_EXPERIMENTAL_FEATURES - Enable experimental features
  //   IMPARTUS_FLAG_ADVANCED_RATE_LIMITING - Enable adaptive rate limiting
  //   IMPARTUS_FLAG_RETRY_WITH_BACKOFF - Enable exponential backoff retries (default: true)
  //   IMPARTUS_FLAG_PARALLEL_CHUNKS - Enable parallel chunk downloads (default: true)
  //   IMPARTUS_FLAG_DETAILED_PROGRESS - Enable detailed progress reporting (default: true)
  //   IMPARTUS_FLAG_METRICS_EXPORT - Enable OpenTelemetry metrics export
  //   IMPARTUS_FLAG_ALERTING - Enable webhook alerting
  //   IMPARTUS_FLAG_SENTRY_ERRORS - Enable Sentry error tracking
  //   IMPARTUS_FLAG_WS_COMPRESSION - Enable WebSocket compression (default: true)
  //   IMPARTUS_FLAG_STREAMING_RESPONSE - Enable streaming responses
  //   IMPARTUS_FLAG_METRICS_ENDPOINT - Enable /metrics endpoint
  "featureFlags": {
    "enableVerboseLogging": false,
    "enableExperimentalFeatures": false,
    "enableAdvancedRateLimiting": false,
    "enableRetryWithBackoff": true,
    "enableParallelChunkDownloads": true,
    "enableDetailedProgress": true,
    "enableMetricsExport": false,
    "enableAlerting": false,
    "enableSentryErrors": false,
    "enableWebSocketCompression": true,
    "enableStreamingResponse": false,
    "enableMetricsEndpoint": false
  }
}
