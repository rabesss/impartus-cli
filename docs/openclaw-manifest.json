{
  "name": "impartus",
  "description": "CLI and HTTP API for downloading Impartus lecture recordings. Supports interactive and deterministic JSON modes for human and agent use.",
  "version": "0.1.7",
  "author": "rabesss",
  "homepage": "https://github.com/rabesss/impartus-cli",
  "endpoints": {
    "baseUrl": "http://localhost:8080/api/v1",
    "websocket": "ws://localhost:8080/api/v1/ws",
    "health": "http://localhost:8080/api/v1/health"
  },
  "authentication": {
    "type": "bearer",
    "loginEndpoint": "POST /api/v1/auth/login",
    "header": "Authorization: Bearer {token}",
    "tokenLifetime": "24h",
    "tokenGeneration": "crypto/rand 32-byte, base64url-encoded",
    "cleanupInterval": "1h"
  },
  "cli": {
    "binary": "impartus",
    "globalFlags": [
      "--json"
    ],
    "commands": [
      {
        "name": "help",
        "usage": "impartus help",
        "description": "Show usage information"
      },
      {
        "name": "version",
        "usage": "impartus version",
        "description": "Show version and build date"
      },
      {
        "name": "courses",
        "usage": "impartus courses",
        "description": "List courses as JSON array"
      },
      {
        "name": "lectures",
        "usage": "impartus lectures --subject <id> --session <id>",
        "description": "List lectures as JSON array",
        "flags": {
          "--subject/-s": "Subject ID (required)",
          "--session/-S": "Session ID (required)"
        }
      },
      {
        "name": "download",
        "usage": "impartus download --subject <id> --session <id> [--start N] [--end N]",
        "description": "Download lectures",
        "flags": {
          "--subject/-s": "Subject ID (required)",
          "--session/-S": "Session ID (required)",
          "--start": "Start lecture index (1-based)",
          "--end": "End lecture index (1-based)",
          "--quality": "Quality override (144|450|720)",
          "--views": "Views override (first/second/both or left/right/both)",
          "--audio-only": "Audio-only mode",
          "--format": "Audio format override (mp3|m4a|aac|opus)",
          "--output/-o": "Output directory"
        }
      },
      {
        "name": "serve",
        "usage": "impartus serve [--port <port>]",
        "description": "Start HTTP API server (default port 8080)",
        "flags": {
          "--port": "Port number (default: 8080)"
        }
      }
    ],
    "jsonMode": {
      "flag": "--json",
      "description": "Returns deterministic JSON envelopes for automation. Can appear before or after the subcommand.",
      "envelope": {
        "success": "boolean",
        "data": "object | null",
        "error": "{ message: string } | null",
        "meta": "{ command: string, mode: 'json' }"
      },
      "notes": [
        "No subcommand + --json returns capability metadata (help envelope)",
        "serve --json is non-blocking: returns startup metadata without starting the server",
        "download --json suppresses stdout/stderr and returns completion envelope"
      ]
    }
  },
  "tools": [
    {
      "name": "login",
      "description": "Authenticate with Impartus credentials and receive a bearer token",
      "endpoint": "POST /api/v1/auth/login",
      "authentication": "none",
      "parameters": {
        "username": {
          "type": "string",
          "required": true,
          "description": "Impartus username (email)"
        },
        "password": {
          "type": "string",
          "required": true,
          "description": "Impartus password"
        }
      },
      "response": {
        "format": "respondWithSuccess envelope",
        "fields": {
          "success": {
            "type": "boolean",
            "value": true
          },
          "data": {
            "type": "object",
            "fields": {
              "token": {
                "type": "string",
                "description": "Bearer token (base64url, 32-byte entropy)"
              },
              "expires": {
                "type": "string",
                "format": "ISO 8601",
                "description": "Token expiry timestamp (24h from creation)"
              }
            }
          }
        }
      },
      "errors": [
        "INVALID_REQUEST",
        "AUTH_FAILED",
        "TOKEN_GENERATION_FAILED"
      ]
    },
    {
      "name": "list_courses",
      "description": "List all available courses for the authenticated user",
      "endpoint": "GET /api/v1/courses",
      "authentication": "required",
      "parameters": {},
      "response": {
        "format": "respondWithEnvelope",
        "envelope": {
          "success": {
            "type": "boolean",
            "value": true
          },
          "data": {
            "type": "array",
            "items": {
              "sessionId": {
                "type": "integer"
              },
              "subjectId": {
                "type": "integer"
              },
              "subjectName": {
                "type": "string"
              },
              "professorName": {
                "type": "string"
              },
              "sessionName": {
                "type": "string"
              },
              "institute": {
                "type": "string"
              },
              "department": {
                "type": "string"
              },
              "videoCount": {
                "type": "integer"
              }
            }
          },
          "meta": {
            "type": "object",
            "description": "{ command: string, mode: 'api' }"
          }
        }
      },
      "errors": [
        "MISSING_TOKEN",
        "INVALID_TOKEN_FORMAT",
        "INVALID_TOKEN",
        "LOGIN_FAILED",
        "COURSES_FETCH_FAILED"
      ]
    },
    {
      "name": "list_lectures",
      "description": "List all lectures for a specific course",
      "endpoint": "GET /api/v1/lectures",
      "authentication": "required",
      "parameters": {
        "subject_id": {
          "type": "integer",
          "required": true,
          "description": "Subject ID",
          "location": "query",
          "aliases": [
            "subjectId"
          ]
        },
        "session_id": {
          "type": "integer",
          "required": true,
          "description": "Session ID",
          "location": "query",
          "aliases": [
            "sessionId"
          ]
        }
      },
      "response": {
        "format": "respondWithEnvelope",
        "envelope": {
          "success": {
            "type": "boolean",
            "value": true
          },
          "data": {
            "type": "array",
            "items": {
              "videoId": {
                "type": "integer"
              },
              "seqNo": {
                "type": "integer"
              },
              "topic": {
                "type": "string"
              },
              "startTime": {
                "type": "string",
                "format": "ISO 8601"
              },
              "endTime": {
                "type": "string",
                "format": "ISO 8601"
              },
              "actualDuration": {
                "type": "integer"
              },
              "subjectName": {
                "type": "string"
              }
            }
          },
          "meta": {
            "type": "object",
            "description": "{ command: string, mode: 'api' }"
          }
        }
      },
      "errors": [
        "MISSING_TOKEN",
        "INVALID_TOKEN_FORMAT",
        "INVALID_TOKEN",
        "MISSING_PARAMETER",
        "INVALID_REQUEST",
        "LOGIN_FAILED",
        "LECTURES_FETCH_FAILED"
      ]
    },
    {
      "name": "download_lectures",
      "description": "Create a new download job for lectures",
      "endpoint": "POST /api/v1/jobs",
      "authentication": "required",
      "parameters": {
        "subjectId": {
          "type": "integer",
          "required": true,
          "description": "Subject ID (> 0)"
        },
        "sessionId": {
          "type": "integer",
          "required": true,
          "description": "Session ID (> 0)"
        },
        "startIndex": {
          "type": "integer",
          "required": true,
          "description": "Starting lecture index (1-based, >= 1, matching CLI --start)"
        },
        "endIndex": {
          "type": "integer",
          "required": true,
          "description": "Ending lecture index (1-based, >= startIndex, inclusive, matching CLI --end)"
        },
        "idempotencyKey": {
          "type": "string",
          "required": false,
          "description": "Optional idempotency key (max 256 chars). If provided and a job with this key already exists, returns the existing job with 409 Conflict instead of creating a duplicate. Keys are persisted and survive server restarts. Omitting the key always creates a new job."
        },
        "jobConfig": {
          "type": "object",
          "required": false,
          "description": "Optional per-job config overrides. If provided, top-level compatibility fields are ignored.",
          "fields": {
            "quality": {
              "type": "string",
              "enum": [
                "144",
                "450",
                "720"
              ]
            },
            "views": {
              "type": "string",
              "enum": [
                "first",
                "second",
                "both"
              ]
            },
            "audioOnly": {
              "type": "boolean"
            },
            "audioFormat": {
              "type": "string",
              "enum": [
                "mp3",
                "m4a",
                "aac",
                "opus"
              ]
            },
            "outputPath": {
              "type": "string",
              "description": "Non-empty output directory"
            },
            "enablePipeline": {
              "type": "boolean"
            },
            "numWorkers": {
              "type": "integer",
              "range": "1-50"
            },
            "downloadWorkersPerLecture": {
              "type": "integer",
              "range": "1-10"
            },
            "decryptWorkersPerLecture": {
              "type": "integer",
              "range": "1-10"
            }
          }
        }
      },
      "backwardCompatibility": "All jobConfig fields are also accepted at the top level for backward compatibility. If jobConfig is present, top-level fields are ignored.",
      "response": {
        "status": 201,
        "note": "Returns Job object directly",
        "duplicateResponse": {
          "status": 409,
          "format": "respondWithEnvelope",
          "description": "Returned when idempotencyKey is provided and a job with that key already exists. Returns the existing job instead of creating a duplicate.",
          "envelope": {
            "success": {
              "type": "boolean",
              "value": true
            },
            "data": {
              "type": "object",
              "fields": {
                "job": {
                  "type": "object",
                  "description": "The existing Job object"
                },
                "duplicate": {
                  "type": "boolean",
                  "value": true
                }
              }
            },
            "meta": {
              "type": "object",
              "description": "{ command: string, mode: 'api' }"
            }
          }
        },
        "fields": {
          "id": {
            "type": "string",
            "description": "Job ID (format: job-{unixNano})"
          },
          "subjectId": {
            "type": "integer"
          },
          "sessionId": {
            "type": "integer"
          },
          "startIndex": {
            "type": "integer"
          },
          "endIndex": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "running",
              "completed",
              "failed",
              "canceled"
            ]
          },
          "progress": {
            "type": "number",
            "description": "0-100"
          },
          "error": {
            "type": "string",
            "description": "Error message if failed"
          },
          "totalLectures": {
            "type": "integer",
            "description": "Total lectures in job"
          },
          "completedLectures": {
            "type": "integer",
            "description": "Completed lectures count"
          },
          "outputs": {
            "type": "array",
            "items": "string",
            "description": "Output file paths"
          },
          "config": {
            "type": "object",
            "description": "Resolved runtime config (merged defaults + overrides)",
            "fields": {
              "quality": {
                "type": "string"
              },
              "views": {
                "type": "string"
              },
              "audioOnly": {
                "type": "boolean"
              },
              "audioFormat": {
                "type": "string"
              },
              "outputPath": {
                "type": "string"
              },
              "enablePipeline": {
                "type": "boolean"
              },
              "numWorkers": {
                "type": "integer"
              },
              "downloadWorkersPerLecture": {
                "type": "integer"
              },
              "decryptWorkersPerLecture": {
                "type": "integer"
              },
              "slides": {
                "type": "boolean"
              }
            }
          },
          "createdAt": {
            "type": "string",
            "format": "ISO 8601"
          },
          "updatedAt": {
            "type": "string",
            "format": "ISO 8601"
          }
        }
      },
      "errors": [
        "MISSING_TOKEN",
        "INVALID_TOKEN_FORMAT",
        "INVALID_TOKEN",
        "INVALID_REQUEST",
        "MISSING_PARAMETER",
        "INVALID_IDEMPOTENCY_KEY",
        "INVALID_JOB_CONFIG"
      ]
    },
    {
      "name": "list_jobs",
      "description": "List all download jobs",
      "endpoint": "GET /api/v1/jobs",
      "authentication": "required",
      "response": {
        "format": "respondWithEnvelope",
        "envelope": {
          "success": {
            "type": "boolean",
            "value": true
          },
          "data": {
            "type": "array",
            "items": "Job object (same schema as download_lectures response)"
          },
          "meta": {
            "type": "object",
            "description": "{ command: string, mode: 'api' }"
          }
        }
      },
      "errors": [
        "MISSING_TOKEN",
        "INVALID_TOKEN_FORMAT",
        "INVALID_TOKEN"
      ]
    },
    {
      "name": "get_job",
      "description": "Get status of a specific job",
      "endpoint": "GET /api/v1/jobs/{id}",
      "authentication": "required",
      "parameters": {
        "id": {
          "type": "string",
          "required": true,
          "description": "Job ID",
          "location": "path"
        }
      },
      "response": "Job object (same schema as download_lectures response)",
      "errors": [
        "MISSING_TOKEN",
        "INVALID_TOKEN_FORMAT",
        "INVALID_TOKEN",
        "MISSING_PARAMETER",
        "JOB_NOT_FOUND"
      ]
    },
    {
      "name": "cancel_job",
      "description": "Cancel a pending or running job",
      "endpoint": "DELETE /api/v1/jobs/{id}",
      "authentication": "required",
      "parameters": {
        "id": {
          "type": "string",
          "required": true,
          "description": "Job ID",
          "location": "path"
        }
      },
      "response": {
        "format": "respondWithSuccess envelope",
        "fields": {
          "success": {
            "type": "boolean",
            "value": true
          },
          "data": {
            "type": "object",
            "fields": {
              "id": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "value": "canceled"
              }
            }
          }
        }
      },
      "errors": [
        "MISSING_TOKEN",
        "INVALID_TOKEN_FORMAT",
        "INVALID_TOKEN",
        "MISSING_PARAMETER",
        "JOB_NOT_FOUND",
        "JOB_CANNOT_CANCEL",
        "CANCEL_FAILED"
      ]
    },
    {
      "name": "health_check",
      "description": "Check if the API server is running and its dependencies (config, upstream API, FFmpeg)",
      "endpoint": "GET /api/v1/health",
      "authentication": "none",
      "parameters": {},
      "response": {
        "format": "respondWithEnvelope",
        "envelope": {
          "success": {
            "type": "boolean",
            "value": true
          },
          "data": {
            "type": "object",
            "fields": {
              "status": {
                "type": "string",
                "description": "Overall status: 'ok' or 'degraded'"
              },
              "config": {
                "type": "object",
                "description": "Config validation checks (username, password, baseUrl)",
                "fields": {
                  "status": {
                    "type": "string",
                    "description": "'ok' or 'misconfigured'"
                  },
                  "username": {
                    "type": "string",
                    "description": "'ok' or 'missing'"
                  },
                  "password": {
                    "type": "string",
                    "description": "'ok' or 'missing'"
                  },
                  "baseUrl": {
                    "type": "string",
                    "description": "'ok' or 'missing'"
                  }
                }
              },
              "upstream": {
                "type": "object",
                "description": "Impartus API reachability check",
                "fields": {
                  "status": {
                    "type": "string",
                    "description": "'reachable' or 'unreachable'"
                  }
                }
              },
              "ffmpeg": {
                "type": "object",
                "description": "FFmpeg availability check",
                "fields": {
                  "status": {
                    "type": "string",
                    "description": "'available' or 'not_found'"
                  }
                }
              }
            }
          },
          "meta": {
            "type": "object",
            "description": "{ command: string, mode: 'api' }"
          }
        }
      }
    }
  ],
  "websocket": {
    "endpoint": "ws://localhost:8080/api/v1/ws",
    "authentication": {
      "header": "Authorization: Bearer {token}",
      "required": true
    },
    "events": [
      {
        "type": "job.started",
        "description": "Emitted when a job begins execution",
        "fields": {
          "type": {
            "type": "string",
            "value": "job.started"
          },
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "value": "running"
          },
          "timestamp": {
            "type": "integer",
            "description": "Unix timestamp (seconds)"
          }
        }
      },
      {
        "type": "job.progress",
        "description": "Emitted periodically as download progresses",
        "fields": {
          "type": {
            "type": "string",
            "value": "job.progress"
          },
          "jobId": {
            "type": "string"
          },
          "progress": {
            "type": "number",
            "description": "0-100"
          },
          "status": {
            "type": "string",
            "value": "running"
          },
          "phase": {
            "type": "string",
            "enum": [
              "initializing",
              "logging_in",
              "fetching_lectures",
              "downloading_slides",
              "fetching_playlists",
              "downloading"
            ]
          },
          "details": {
            "type": "object",
            "description": "Optional phase-specific metadata",
            "fields": {
              "completedLectures": {
                "type": "integer"
              },
              "totalLectures": {
                "type": "integer"
              }
            }
          },
          "timestamp": {
            "type": "integer",
            "description": "Unix timestamp (seconds)"
          }
        }
      },
      {
        "type": "job.completed",
        "description": "Emitted when all lectures finish successfully",
        "fields": {
          "type": {
            "type": "string",
            "value": "job.completed"
          },
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "value": "completed"
          },
          "progress": {
            "type": "number",
            "value": 100
          },
          "outputs": {
            "type": "array",
            "items": "string",
            "description": "Output file paths"
          },
          "timestamp": {
            "type": "integer",
            "description": "Unix timestamp (seconds)"
          }
        }
      },
      {
        "type": "job.failed",
        "description": "Emitted when a job errors and cannot continue",
        "fields": {
          "type": {
            "type": "string",
            "value": "job.failed"
          },
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "value": "failed"
          },
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "timestamp": {
            "type": "integer",
            "description": "Unix timestamp (seconds)"
          }
        }
      },
      {
        "type": "job.cancelled",
        "description": "Emitted when a job is cancelled via DELETE",
        "fields": {
          "type": {
            "type": "string",
            "value": "job.cancelled"
          },
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "value": "canceled"
          },
          "progress": {
            "type": "number",
            "description": "Progress at time of cancellation (may be omitted)"
          },
          "timestamp": {
            "type": "integer",
            "description": "Unix timestamp (seconds)"
          }
        }
      }
    ]
  },
  "configuration": {
    "configFile": {
      "path": "./config.json",
      "description": "JSON configuration file. Copy sample.config.json and fill in credentials.",
      "properties": {
        "username": "Impartus username (email)",
        "password": "Impartus password",
        "baseUrl": "Impartus API base URL",
        "quality": "Default video quality (144|450|720)",
        "views": "Default views (left|right|both)",
        "downloadLocation": "Default output directory",
        "tempDirLocation": "Default temp directory",
        "slides": "Download slides (true/false)",
        "numWorkers": "Default concurrent workers (1-50)",
        "audioOnly": "Download audio only (true/false)",
        "audioFormat": "Audio format (mp3|m4a|aac|opus)",
        "rateLimit": "Download rate limit (requests/second)",
        "apiRateLimit": "API rate limit (requests/second)",
        "enableJitter": "Add random delays (true/false)",
        "httpTimeout": "HTTP timeout for chunk downloads (e.g. 10m)",
        "enablePipeline": "Use pipelined download+decrypt (true/false)",
        "downloadWorkersPerLecture": "Pipeline download workers (1-10)",
        "decryptWorkersPerLecture": "Pipeline decrypt workers (1-10)",
        "progressTracking": {
          "enabled": "Enable progress bars (true/false)",
          "showSpeed": "Show download speed (true/false)",
          "showETA": "Show ETA (true/false)",
          "updateInterval": "Progress update interval (e.g. 2s)",
          "speedWindowSize": "Speed moving average window size"
        }
      }
    }
  },
  "errorCodes": {
    "format": {
      "success": false,
      "error": {
        "code": "ERROR_CODE",
        "message": "Human readable description",
        "details": {}
      }
    },
    "retryHints": {
      "description": "Some errors include retry hints to guide client retry behavior",
      "format": {
        "retryable": {
          "type": "boolean",
          "description": "True if the operation may succeed on retry"
        },
        "retryAfter": {
          "type": "integer",
          "description": "Seconds to wait before retrying (only present when retryable=true)"
        }
      },
      "codes": {
        "LOGIN_FAILED": {
          "retryable": true,
          "retryAfter": 30,
          "status": 502
        },
        "COURSES_FETCH_FAILED": {
          "retryable": true,
          "retryAfter": 30,
          "status": 502
        },
        "LECTURES_FETCH_FAILED": {
          "retryable": true,
          "retryAfter": 30,
          "status": 502
        },
        "CANCEL_FAILED": {
          "retryable": true,
          "retryAfter": 10,
          "status": 500
        }
      },
      "notes": [
        "4xx client errors (INVALID_REQUEST, MISSING_PARAMETER, etc.) do NOT include retryable field",
        "Absence of retryable field means the error is not retryable"
      ]
    },
    "codes": {
      "INVALID_IDEMPOTENCY_KEY": {
        "status": 400,
        "description": "idempotencyKey must be at most 256 characters"
      },
      "INVALID_REQUEST": {
        "status": 400,
        "description": "Malformed request body or invalid field value"
      },
      "MISSING_PARAMETER": {
        "status": 400,
        "description": "Required parameter not provided or invalid"
      },
      "MISSING_TOKEN": {
        "status": 401,
        "description": "No Authorization header on protected route"
      },
      "INVALID_TOKEN_FORMAT": {
        "status": 401,
        "description": "Authorization header not in Bearer format"
      },
      "INVALID_TOKEN": {
        "status": 401,
        "description": "Token not found or expired"
      },
      "AUTH_FAILED": {
        "status": 401,
        "description": "Invalid username or password"
      },
      "TOKEN_GENERATION_FAILED": {
        "status": 500,
        "description": "Failed to generate auth token"
      },
      "LOGIN_FAILED": {
        "status": 502,
        "description": "Failed to authenticate with Impartus API"
      },
      "COURSES_FETCH_FAILED": {
        "status": 502,
        "description": "Failed to fetch courses from Impartus"
      },
      "LECTURES_FETCH_FAILED": {
        "status": 502,
        "description": "Failed to fetch lectures from Impartus"
      },
      "JOB_NOT_FOUND": {
        "status": 404,
        "description": "Job ID does not exist"
      },
      "JOB_CANNOT_CANCEL": {
        "status": 400,
        "description": "Job in terminal state (completed/failed/cancelled). details.status has the state."
      },
      "INVALID_JOB_CONFIG": {
        "status": 400,
        "description": "Invalid jobConfig override values"
      },
      "CANCEL_FAILED": {
        "status": 500,
        "description": "Unexpected failure during cancellation"
      }
    }
  },
  "examples": {
    "basicUsage": {
      "description": "Login, browse courses, and download via API",
      "steps": [
        "1. POST /api/v1/auth/login with username/password → get token",
        "2. GET /api/v1/courses with Bearer token → list courses",
        "3. GET /api/v1/lectures?subject_id=X&session_id=Y → list lectures",
        "4. POST /api/v1/jobs with subjectId, sessionId, startIndex, endIndex → create job (201)",
        "5. Connect to WebSocket at ws://localhost:8080/api/v1/ws with Bearer token → track progress",
        "6. GET /api/v1/jobs/{id} to poll status, or DELETE to cancel"
      ]
    },
    "downloadWithOverrides": {
      "description": "Download lectures 1-6 (first 6) with quality and pipeline overrides",
      "request": {
        "method": "POST",
        "endpoint": "/api/v1/jobs",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {token}"
        },
        "body": {
          "subjectId": 678,
          "sessionId": 12345,
          "startIndex": 1,
          "endIndex": 6,
          "jobConfig": {
            "quality": "720",
            "views": "both",
            "enablePipeline": true,
            "numWorkers": 6
          }
        }
      }
    },
    "cliJsonMode": {
      "description": "Use CLI in deterministic JSON mode for automation",
      "commands": [
        "impartus --json                          # capability metadata",
        "impartus courses --json                  # course list in envelope",
        "impartus lectures -s 123 -S 456 --json   # lecture list in envelope",
        "impartus serve --json --port 9090         # startup metadata (non-blocking)"
      ]
    },
    "monitorProgress": {
      "description": "Monitor job progress via authenticated WebSocket",
      "javascript": "import WebSocket from 'ws';\n\nconst ws = new WebSocket('ws://localhost:8080/api/v1/ws', {\n  headers: { Authorization: `Bearer ${token}` }\n});\n\nws.onmessage = (event) => {\n  const data = JSON.parse(event.data);\n  console.log(data.type, data);\n};"
    }
  },
  "knownLimitations": [
    "Lectures endpoint uses query params (subject_id, session_id) instead of RESTful path params",
    "Job ID is Unix timestamp-based (job-{unixNano}), not UUID",
    "Job responses use 'id' field, not 'jobId'",
    "WebSocket events have no 'data' wrapper — additional fields are at top level",
    "WebSocket timestamps are Unix integers, not ISO 8601 strings",
    "List responses (courses, lectures, jobs) are wrapped in {success, data, error, meta} envelope",
    "Upstream error messages may be passed through to API clients on 502 responses"
  ],
  "jobPersistence": {
    "description": "Jobs are persisted to disk and survive server restarts",
    "persistenceFile": ".jobs.json",
    "persistedData": [
      "Job ID, subjectId, sessionId, startIndex, endIndex",
      "Job status, progress, outputs, error message",
      "Job config (quality, views, audioOnly, etc.)",
      "Idempotency key (if provided)",
      "CreatedAt and UpdatedAt timestamps"
    ],
    "notPersisted": [
      "Credentials (username, password, tokens)",
      "Runtime context (download progress, active connections)"
    ],
    "restartBehavior": {
      "pending": "Jobs in pending state are marked as 'failed' (cannot be resumed)",
      "running": "Jobs that were running are marked as 'failed' on restart (cannot be resumed)",
      "completed": "Jobs in completed state are restored as completed",
      "failed": "Jobs in failed state are restored as failed",
      "canceled": "Jobs in canceled state are restored as canceled"
    },
    "idempotencyKeys": "Idempotency keys are persisted alongside jobs. Duplicate key submissions after restart return the existing job."
  }
}
